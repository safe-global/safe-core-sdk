{
  "name": "safe-core-sdk",
  "private": true,
  "scripts": {
    "clean": "pnpm -r exec -- rm -rf node_modules",
    "unbuild": "pnpm -r run unbuild",
    "build": "pnpm -r run build",
    "lint:check": "eslint './packages/**/*.{js,jsx,ts,tsx}'",
    "test": "FORCE_COLOR=1 pnpm -r run test",
    "play": "ts-node ./playground/config/run.ts",
    "format": "pnpm -r run format && prettier --write \"playground/**/*.ts\"",
    "prepare": "husky",
    "generate-publish-info": "ts-node ./scripts/generate-publish-info.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.16.0"
  },
  "author": "Safe (https://safe.global)",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@safe-global/api-kit": "workspace:^",
    "@safe-global/protocol-kit": "workspace:^",
    "@safe-global/relay-kit": "workspace:^",
    "@safe-global/sdk-starter-kit": "workspace:^",
    "@safe-global/types-kit": "workspace:^",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "rimraf": "^5.0.10",
    "semver": "^7.8.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.6.3",
    "viem": "^2.52.2"
  },
  "lint-staged": {
    "./packages/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "./packages/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
